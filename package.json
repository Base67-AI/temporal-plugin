{
  "name": "@base67/temporal-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Temporal.io-based durable orchestration for Claude Code sub-agent workflows",
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "worker": "ts-node src/worker.ts",
    "client": "ts-node src/client.ts",
    "test": "mocha --require ts-node/register test/**/*.test.ts --timeout 10000"
  },
  "dependencies": {
    "@temporalio/activity": "^1.15.0",
    "@temporalio/client": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.15.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "mocha": "^10.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
